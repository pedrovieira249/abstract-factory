{
    "name": "user/abstractfactory",
    "description": "Exemplo do Design Patterns Abstract Factory",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Pedro Vieira"
        }
    ],
    "require": {
        "php": ">=8.1",
        "composer-runtime-api": "^2.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "User\\Abstractfactory\\": "src/"
        }
    },
    "config": {
        "platform": {
            "php": "8.1"
        },
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
